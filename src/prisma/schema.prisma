generator client {
  provider = "prisma-client-js" // legacy — pinned for Next 16 Turbopack compat
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?  @map("password_hash")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categories    Category[]
  planningItems PlanningItem[]

  @@map("users")
}

/// Uniqueness of (userId, name) is scoped to non-deleted rows only, enforced
/// via a hand-written partial unique index (Prisma's schema DSL cannot
/// express `WHERE deleted_at IS NULL`) — see the
/// `categories_lists_soft_delete` migration, not here.
model Category {
  id        String    @id @default(cuid())
  userId    String
  name      String
  color     String?
  icon      String?
  sortOrder Int       @default(0) @map("sort_order")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lists List[]

  @@index([userId])
  @@index([userId, deletedAt])
  @@map("categories")
}

/// Uniqueness of (categoryId, name) is scoped to non-deleted rows only,
/// enforced via a hand-written partial unique index — see the
/// `categories_lists_soft_delete` migration, not here.
model List {
  id         String    @id @default(cuid())
  categoryId String
  name       String
  sortOrder  Int       @default(0) @map("sort_order")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  category      Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  planningItems PlanningItem[]

  @@index([categoryId])
  @@index([categoryId, deletedAt])
  @@map("lists")
}

/// At most one row may have isDefault = true. Prisma's schema DSL cannot
/// express a partial unique index, so this invariant is enforced via a
/// hand-written migration (see
/// `migrations/20260713005908_single_default_partial_unique`), not here.
model ItemType {
  id                 String   @id @default(cuid())
  key                String   @unique
  name               String
  color              String?
  icon               String?
  sortOrder          Int      @default(0) @map("sort_order")
  active             Boolean  @default(true)
  isDefault          Boolean  @default(false) @map("is_default")
  requiresCompletion Boolean  @default(false) @map("requires_completion")
  allowsRepetition   Boolean  @default(false) @map("allows_repetition")
  allowsProgress     Boolean  @default(false) @map("allows_progress")
  allowsChecklist    Boolean  @default(false) @map("allows_checklist")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  planningItems PlanningItem[]

  @@map("item_types")
}

model Priority {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  color     String?
  icon      String?
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planningItems PlanningItem[]

  @@map("priorities")
}

/// At most one row may have isDefault = true. Prisma's schema DSL cannot
/// express a partial unique index, so this invariant is enforced via a
/// hand-written migration (see
/// `migrations/20260713005908_single_default_partial_unique`), not here.
model Status {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  color     String?
  icon      String?
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planningItems PlanningItem[]

  @@map("statuses")
}

model PlanningItem {
  id          String    @id @default(cuid())
  userId      String
  listId      String
  itemTypeId  String
  priorityId  String?
  statusId    String
  title       String
  description String?
  dueAt          DateTime? @map("due_at")
  startAt        DateTime? @map("start_at")
  endAt          DateTime? @map("end_at")
  allDay         Boolean   @default(false) @map("all_day")
  remindAt       DateTime? @map("remind_at")
  reminderSeenAt DateTime? @map("reminder_seen_at")
  objectiveStartAt DateTime? @map("objective_start_at")
  objectiveEndAt   DateTime? @map("objective_end_at")
  progress         Int?      @map("progress")
  archived       Boolean   @default(false)
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  list     List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  itemType ItemType  @relation(fields: [itemTypeId], references: [id], onDelete: Restrict)
  priority Priority? @relation(fields: [priorityId], references: [id], onDelete: SetNull)
  status   Status    @relation(fields: [statusId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([listId])
  @@index([itemTypeId])
  @@index([statusId])
  @@index([priorityId])
  @@index([startAt])
  @@index([userId, archived, deletedAt])
  @@index([userId, remindAt])
  @@index([userId, objectiveEndAt])
  @@map("planning_items")
}
